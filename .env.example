BOT_TOKEN=your_telegram_bot_token_here
ADMIN_TELEGRAM_ID=123456789
# INVITE_LINK_SECRET=opcional_secreto_para_enlaces_invitacion  # si no se define, se usa BOT_TOKEN
# GATE_PROXY_URL=https://tu-servicio-del-porton/abrir  # cuando un invitado usa /gate_open, este bot hace POST aquí
# GATE_PROXY_SECRET=secreto_compartido_con_el_servicio_del_porton
# Network Config (required for Docker -> Host Windows SSH)
PC_MAC=AA:BB:CC:DD:EE:FF
PC_IP=192.168.1.46  # The host's LAN IP
SSH_USER=username
SSH_KEY_PATH=/home/bot/.ssh/id_rsa
# SSH_PORT=22  # optional, default 22

# ACE-Step
ACESTEP_PATH=C:\path\to\ACE-Step-1.5
ACESTEP_HOST=192.168.1.46  # Same as PC_IP or host.docker.internal
ACESTEP_PORT=8001
ACESTEP_SAVE_PATH=C:\telegram_songs
# ACESTEP_REMOTE_BAT=start_api_server_docker_remote.bat  # optional: run this .bat on remote as-is (must exist in ACESTEP_PATH)

# Enabled Modules (comma-separated list)
# Available: pc, gate, acestep, ollama, zigbee, arlo, scheduler
ENABLED_MODULES=pc,gate,acestep,ollama,zigbee,arlo,scheduler

# Ollama
OLLAMA_BASE_URL=http://192.168.1.46:11434
OLLAMA_MODEL=llama3
