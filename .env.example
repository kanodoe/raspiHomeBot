# Token del bot. Con un solo proceso puede usarse solo BOT_TOKEN.
# Con varios bots (BOT_MODE=admin|songs|gate) cada proceso puede tener su token:
BOT_TOKEN=your_telegram_bot_token_here
# BOT_TOKEN_ADMIN=token_del_bot_admin
# BOT_TOKEN_SONGS=token_del_bot_canciones
# BOT_TOKEN_GATE=token_del_bot_porton
# Si no se define el token del modo (ej. BOT_TOKEN_SONGS), se usa BOT_TOKEN.
ADMIN_TELEGRAM_ID=123456789
# INVITE_LINK_SECRET: obligatorio si usas varios bots (admin/songs/gate). Mismo valor en TODOS los .env para que los enlaces funcionen al abrirlos en el bot de canciones/portón.
# INVITE_LINK_SECRET=un_mismo_secreto_largo_en_todos_los_procesos
# GATE_PROXY_URL=https://tu-servicio-del-porton/abrir  # cuando un invitado usa /gate_open, este bot hace POST aquí
# GATE_PROXY_SECRET=secreto_compartido_con_el_servicio_del_porton
# Network Config (required for Docker -> Host Windows SSH)
PC_MAC=AA:BB:CC:DD:EE:FF
PC_IP=192.168.1.46  # The host's LAN IP
SSH_USER=username
SSH_KEY_PATH=/home/bot/.ssh/id_rsa
# SSH_PORT=22  # optional, default 22

# ACE-Step
ACESTEP_PATH=C:\path\to\ACE-Step-1.5
ACESTEP_HOST=192.168.1.46  # Same as PC_IP or host.docker.internal
ACESTEP_PORT=8001
ACESTEP_SAVE_PATH=C:\telegram_songs
# ACESTEP_REMOTE_BAT=start_api_server_docker_remote.bat  # optional: run this .bat on remote as-is (must exist in ACESTEP_PATH)

# Enabled Modules (comma-separated list)
# Available: pc, gate, acestep, ollama, zigbee, arlo, scheduler
ENABLED_MODULES=pc,gate,acestep,ollama,zigbee,arlo,scheduler

# Multi-bot: admin | songs | gate (one mode per process). Solo usuarios con invitación (o admin) pueden usar los bots.
# BOT_MODE=admin
# SONGS_BOT_USERNAME=raspi_song_bot   # Enlace público: t.me/raspi_song_bot (sin @)
# GATE_BOT_USERNAME=MyGateBot
# PORTON_CHANNEL_ID=-1001234567890
# API_KEY=optional_secret_for_api_read_endpoints
# PORT=8000  # Puerto HTTP. Con docker-compose, admin=8000 y songs=8001 para no colisionar (network_mode: host).

# Ollama
OLLAMA_BASE_URL=http://192.168.1.46:11434
OLLAMA_MODEL=llama3
